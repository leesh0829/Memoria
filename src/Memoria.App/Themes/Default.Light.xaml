<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="Brush.WindowBackground"           Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Surface"                    Color="#F4F5F7" />
    <SolidColorBrush x:Key="Brush.SidebarBackground"          Color="#F4F5F7" />
    <SolidColorBrush x:Key="Brush.ToolbarBackground"          Color="#F2F3F5" />
    <SolidColorBrush x:Key="Brush.EditorBackground"           Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Foreground"                 Color="#1A1A1A" />
    <SolidColorBrush x:Key="Brush.SecondaryForeground"        Color="#6B6F76" />
    <SolidColorBrush x:Key="Brush.Border"                     Color="#C5C8CE" />
    <SolidColorBrush x:Key="Brush.ListItemHover"              Color="#EAECEF" />
    <SolidColorBrush x:Key="Brush.ListItemSelected"           Color="#D6E6F5" />
    <SolidColorBrush x:Key="Brush.ListItemSelectedForeground" Color="#0A2A45" />
    <SolidColorBrush x:Key="Brush.Accent"                     Color="#0078D4" />
    <SolidColorBrush x:Key="Brush.AccentForeground"           Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.StrikethroughForeground"    Color="#A0A4AB" />
