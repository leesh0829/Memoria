    <SolidColorBrush x:Key="Brush.WarningBackground"          Color="#FFF4CE" />
    <SolidColorBrush x:Key="Brush.WarningBorder"              Color="#E6C200" />
    <SolidColorBrush x:Key="Brush.WarningForeground"          Color="#6B4E00" />
</ResourceDictionary>
