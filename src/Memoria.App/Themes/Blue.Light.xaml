<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="Brush.WindowBackground"           Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Surface"                    Color="#F2F5FA" />
    <SolidColorBrush x:Key="Brush.SidebarBackground"          Color="#F2F5FA" />
    <SolidColorBrush x:Key="Brush.ToolbarBackground"          Color="#F2F5FA" />
