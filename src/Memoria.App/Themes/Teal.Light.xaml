<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="Brush.WindowBackground"           Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Surface"                    Color="#EDF3F3" />
    <SolidColorBrush x:Key="Brush.SidebarBackground"          Color="#EDF3F3" />
    <SolidColorBrush x:Key="Brush.ToolbarBackground"          Color="#EDF3F3" />
    <SolidColorBrush x:Key="Brush.EditorBackground"           Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Foreground"                 Color="#1A1A1A" />
    <SolidColorBrush x:Key="Brush.SecondaryForeground"        Color="#5A6A6A" />
    <SolidColorBrush x:Key="Brush.Border"                     Color="#BCCBCB" />
    <SolidColorBrush x:Key="Brush.ListItemHover"              Color="#E1EFEF" />
    <SolidColorBrush x:Key="Brush.ListItemSelected"           Color="#C7E5E5" />
    <SolidColorBrush x:Key="Brush.ListItemSelectedForeground" Color="#0A4444" />
    <SolidColorBrush x:Key="Brush.Accent"                     Color="#0C8080" />
    <SolidColorBrush x:Key="Brush.AccentForeground"           Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.StrikethroughForeground"    Color="#9AA6A6" />
    <SolidColorBrush x:Key="Brush.UnclassifiedHighlight"      Color="#FFF3C4" />
    <SolidColorBrush x:Key="Brush.WarningBackground"          Color="#FFF4CE" />
    <SolidColorBrush x:Key="Brush.WarningBorder"              Color="#E3B907" />
    <SolidColorBrush x:Key="Brush.WarningForeground"          Color="#7A5A00" />
</ResourceDictionary>
