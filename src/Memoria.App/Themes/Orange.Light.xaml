<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="Brush.WindowBackground"           Color="#FFFDFB" />
    <SolidColorBrush x:Key="Brush.Surface"                    Color="#F7F2EE" />
    <SolidColorBrush x:Key="Brush.SidebarBackground"          Color="#F7F2EE" />
    <SolidColorBrush x:Key="Brush.ToolbarBackground"          Color="#F6F1ED" />
    <SolidColorBrush x:Key="Brush.EditorBackground"           Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Foreground"                 Color="#1A1A1A" />
    <SolidColorBrush x:Key="Brush.SecondaryForeground"        Color="#6C665F" />
