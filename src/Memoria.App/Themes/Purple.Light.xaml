<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="Brush.WindowBackground"           Color="#FBFAFE" />
    <SolidColorBrush x:Key="Brush.Surface"                    Color="#F3F1F8" />
    <SolidColorBrush x:Key="Brush.SidebarBackground"          Color="#F3F1F8" />
    <SolidColorBrush x:Key="Brush.ToolbarBackground"          Color="#F3F1F8" />
